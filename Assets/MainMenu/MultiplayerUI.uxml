                                            <ui:VisualElement class="status-bar" style="background-color: rgb(255, 87, 19);"/>
                                            <ui:VisualElement class="status-bar" style="background-color: rgb(59, 73, 76);"/>
                                            <ui:VisualElement class="status-bar" style="background-color: rgb(59, 73, 76);"/>
                                        </ui:VisualElement>
                                        <ui:Label text="CHOOSING CAR" class="status-badge" style="background-color: rgb(40, 42, 46); color: rgb(186, 201, 204);"/>
                                    </ui:VisualElement>
                                </ui:VisualElement>
