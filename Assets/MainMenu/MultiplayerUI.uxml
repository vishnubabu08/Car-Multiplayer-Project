                                                <ui:Label text="ELITE / RANK 55" class="text-muted" style="font-size: 8px; -unity-font-style: bold; margin-top: -2px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                                            </ui:VisualElement>
                                        </ui:VisualElement>
                                    </ui:VisualElement>
                                    <ui:VisualElement name="car-3" class="player-car-img" style="background-image: url(&quot;project://database/Assets/ChatGPT%20Image%20Mar%2031,%202026,%2002_56_29%20PM.png?fileID=2800000&amp;guid=44205e96e197f8d4bb7b2e4a7b12d6b2&amp;type=3#ChatGPT Image Mar 31, 2026, 02_56_29 PM&quot;);">
