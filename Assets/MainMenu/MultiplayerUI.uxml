                                            <ui:VisualElement>
                                                <ui:Label text="V_PILOT_01" class="font-headline" style="font-size: 16px;"/>
                                                <ui:Label text="HOST / RANK 42" class="text-muted" style="font-size: 8px; -unity-font-style: bold; margin-top: -2px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                                            </ui:VisualElement>
                                        </ui:VisualElement>
                                    </ui:VisualElement>
                                    <ui:VisualElement name="car-1" class="player-car-img" style="background-image: url(&quot;project://database/Assets/ChatGPT%20Image%20Mar%2031,%202026,%2001_47_24%20PM.png?fileID=2800000&amp;guid=c0fb20d12fd47c14891b9eb20a8665e3&amp;type=3#ChatGPT Image Mar 31, 2026, 01_47_24 PM&quot;);">
                                        <ui:Label text="NEON SPECTER GT" class="car-name-badge text-cyan"/>
                                    </ui:VisualElement>
                                    <ui:VisualElement class="card-bottom-row">
                                        <ui:VisualElement class="status-bars">
                                            <ui:VisualElement class="status-bar" style="background-color: rgb(205, 255, 19);"/>
