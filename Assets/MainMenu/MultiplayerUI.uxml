<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/MainMenu/MultiplayerStyles.uss?fileID=7433441132597879392&amp;guid=22332b4fdfe590144a7f3dabd2e6caae&amp;type=3#MultiplayerStyles"/>
    <Style src="project://database/Assets/MainMenu/SharedStyles.uss?fileID=7433441132597879392&amp;guid=a4d3608c1c99ee94b84d7e1494041657&amp;type=3#SharedStyles"/>
    <ui:VisualElement class="root-container">
        <ui:VisualElement class="top-bar" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);">
            <ui:VisualElement class="top-bar-left">
                <ui:VisualElement class="icon-box-cyan">
                    <ui:Label text="U" style="color: rgb(0, 229, 255); -unity-font-style: bold;"/>
                </ui:VisualElement>
                <ui:Label text="NEON_DRIVE" class="font-black text-cyan" style="font-size: 20px; letter-spacing: 2px;"/>
            </ui:VisualElement>
            <ui:VisualElement class="top-bar-right">
                <ui:VisualElement class="nav-links">
                    <ui:Label text="GARAGE" class="nav-link"/>
                    <ui:Label text="SOCIAL" class="nav-link nav-link-active"/>
                    <ui:Label text="RACE" class="nav-link"/>
                    <ui:Label text="SHOP" class="nav-link"/>
                </ui:VisualElement>
                <ui:VisualElement class="currency-badge">
                    <ui:Label text="15,400 CR" class="font-black text-cyan" style="font-size: 14px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:ScrollView mode="Vertical" style="flex-grow: 1; flex-shrink: 1; width: 100%;">
            <ui:VisualElement class="main-content">
                <ui:VisualElement class="hero-header">
                    <ui:Label text="MULTIPLAYER" class="font-black" style="font-size: 48px; margin-bottom: -16px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);"/>
                    <ui:Label text="LOBBY" class="font-black text-cyan" style="font-size: 48px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);"/>
                    <ui:VisualElement style="flex-direction: row; align-items: center; margin-top: 8px;">
                        <ui:VisualElement style="width: 6px; height: 6px; background-color: rgb(205, 255, 19); margin-right: 8px;"/>
                        <ui:Label text="SERVER: TOKYO_EDGE_01 / LATENCY: 24MS" class="text-muted" style="font-size: 10px; -unity-font-style: bold-and-italic; text-transform: uppercase; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement class="main-row">
                    <ui:VisualElement class="left-col">
                        <ui:Button text="QUICK JOIN" class="btn-quick-join" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);"/>
                        <ui:Button text="CREATE PRIVATE ROOM" class="btn-outline" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);"/>
                        <ui:VisualElement class="input-row">
                            <ui:TextField value="" class="room-input"/>
                            <ui:Button text="&gt;" class="btn-enter"/>
                        </ui:VisualElement>
                        <ui:VisualElement class="chat-panel" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);">
                            <ui:VisualElement class="chat-header">
                                <ui:Label text="TACTICAL COMMS" class="font-headline text-muted" style="color: rgb(255, 255, 255);"/>
                                <ui:Label text="ACTIVE" class="text-lime" style="font-size: 10px; -unity-font-style: bold;"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="chat-message">
                                <ui:Label text="SYSTEM:" class="chat-sender text-cyan"/>
                                <ui:Label text="Lobby encryption established." class="chat-text" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="chat-message">
                                <ui:Label text="X_GHOST:" class="chat-sender text-orange"/>
                                <ui:Label text="Ready to burn some rubber. Which track?" class="chat-text" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                            </ui:VisualElement>
                            <ui:VisualElement class="chat-message">
                                <ui:Label text="CYBER_PUNK:" class="chat-sender text-cyan"/>
                                <ui:Label text="Shinjuku Night Run. Best for drifts." class="chat-text" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                            </ui:VisualElement>
                            <ui:TextField value="TYPE MESSAGE..." class="chat-input"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement class="right-col" style="height: 586px; width: 1043px;">
                        <ui:VisualElement class="grid-header-row">
                            <ui:Label text="CURRENT GRID" class="font-black" style="font-size: 20px;">
                                <ui:Label text="4/8 PLAYERS" class="text-cyan" style="font-size: 10px; margin-left: 12px;"/>
                            </ui:Label>
