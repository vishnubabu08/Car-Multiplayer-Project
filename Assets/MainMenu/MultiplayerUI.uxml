                                            <ui:VisualElement class="status-bar" style="background-color: rgb(205, 255, 19);"/>
                                            <ui:VisualElement class="status-bar" style="background-color: rgb(59, 73, 76);"/>
                                            <ui:VisualElement class="status-bar" style="background-color: rgb(59, 73, 76);"/>
                                        </ui:VisualElement>
                                        <ui:Label text="READY" class="status-badge" style="background-color: rgb(205, 255, 19); color: rgb(17, 19, 24);"/>
