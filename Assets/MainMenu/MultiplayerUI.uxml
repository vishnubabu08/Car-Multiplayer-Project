                        <ui:VisualElement class="player-grid" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Audiowide-Regular.ttf?fileID=12800000&amp;guid=393cc287dbb587548b0cfad5063f5cdb&amp;type=3#Audiowide-Regular&quot;);">
                            <ui:VisualElement class="player-card">
                                <ui:VisualElement class="player-card-inner">
