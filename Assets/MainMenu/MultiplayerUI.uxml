                                <ui:VisualElement class="player-card-inner">
                                    <ui:VisualElement class="player-top-row">
                                        <ui:VisualElement style="flex-direction: row;">
                                            <ui:VisualElement class="avatar-box" style="border-color: rgb(59, 73, 76);"/>
                                            <ui:VisualElement>
                                                <ui:Label text="X_GHOST" class="font-headline" style="font-size: 16px;"/>
                                                <ui:Label text="PRO / RANK 88" class="text-muted" style="font-size: 8px; -unity-font-style: bold; margin-top: -2px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/BrunoAceSC-Regular.ttf?fileID=12800000&amp;guid=68df1285e78444148b9780296a9c63cb&amp;type=3#BrunoAceSC-Regular&quot;);"/>
                                            </ui:VisualElement>
                                        </ui:VisualElement>
                                    </ui:VisualElement>
